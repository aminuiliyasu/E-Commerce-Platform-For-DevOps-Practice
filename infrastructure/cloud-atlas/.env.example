# AWS — uses local profile, never commit real credentials
AWS_PROFILE=default
AWS_REGION=eu-central-1

# Terraform state (matches infrastructure/terraform/backend.tf)
TF_STATE_BUCKET=your-terraform-state-bucket
TF_STATE_KEY=ecommerce/dev/terraform.tfstate
TF_STATE_REGION=eu-central-1

# API
API_PORT=8090
