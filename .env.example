# Copy to .env and fill in values locally. Never commit .env to git.

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=ecommerce
DB_USER=ecommerce
DB_PASSWORD=changeme

# MongoDB
MONGO_URI=mongodb://mongo:27017/ecommerce

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=changeme

# JWT (base64-encoded secret, min 256 bits for HS256)
JWT_SECRET=changeme-generate-a-base64-secret
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Docker Compose — MySQL container
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=ecommerce
MYSQL_USER=ecommerce
MYSQL_PASSWORD=changeme

# Local dev seed users (only used when seeding an empty database)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme
SEED_CUSTOMER_EMAIL=customer@example.com
SEED_CUSTOMER_PASSWORD=changeme

# Server
SERVER_PORT=8080
